{
	"name": "stellar-garden",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@11.13.1",
	"engines": {
		"node": "24"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "oxlint --deny-warnings src/ remotion/",
		"lint:fix": "oxlint --deny-warnings src/ remotion/ --fix",
		"fmt": "oxfmt --write src/",
		"fmt:check": "oxfmt --check src/",
		"cf-typegen": "wrangler types --include-runtime=false",
		"preview": "pnpm run build && vite preview",
		"deploy": "pnpm run build && wrangler deploy",
		"studio": "remotion studio remotion/index.ts",
		"render": "remotion render remotion/index.ts StarField out/video.mp4"
	},
	"dependencies": {
		"@remotion/cli": "^4.0.443",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"remotion": "^4.0.443"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "1.45.0",
		"@types/node": "24.13.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react-swc": "4.3.1",
		"oxfmt": "0.59.0",
		"oxlint": "1.74.0",
		"oxlint-tsgolint": "0.25.0",
		"typescript": "7.0.2",
		"vite": "8.1.5",
		"wrangler": "4.111.0"
	},
	"pnpm": {
		"overrides": {
			"vite": "^8.0.0-beta.13"
		}
	}
}
