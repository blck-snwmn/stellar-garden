{
	"name": "stellar-garden",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@10.24.0",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "oxlint --type-aware --type-check --deny-warnings .",
		"lint:fix": "oxlint --type-aware --type-check --deny-warnings . --fix",
		"fmt": "oxfmt --write src/",
		"fmt:check": "oxfmt --check src/",
		"preview": "pnpm run build && vite preview",
		"deploy": "pnpm run build && wrangler deploy",
		"studio": "remotion studio remotion/index.ts",
		"render": "remotion render remotion/index.ts StarField out/video.mp4"
	},
	"dependencies": {
		"@remotion/cli": "^4.0.443",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"remotion": "^4.0.443"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.30.2",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.2.2",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.57.0",
		"oxlint-tsgolint": "^0.18.1",
		"typescript": "~5.9.3",
		"vite": "^8.0.0-beta.13",
		"wrangler": "^4.78.0"
	},
	"pnpm": {
		"overrides": {
			"vite": "^8.0.0-beta.13"
		}
	}
}